# RAG Document Assistant - Global GitIgnore

# ── Python ────────────────────────────────────────────────────────────────────
venv/
.venv/
env/
__pycache__/
**/__pycache__/
*.py[cod]
*.pyd
*.pyo
*.egg-info/
*.egg
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.Python
*.so
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/
.python-version

# ── Backend runtime ───────────────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep
backend/logs/*
!backend/logs/.gitkeep
backend/coverage/
backend/.nyc_output
*.db
*.sqlite
*.sqlite3
chroma_db/
faiss_index/
vectorstore/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out/
frontend/.angular/cache
frontend/.sass-cache/
frontend/connect.lock
frontend/coverage/
frontend/libpeerconnection.log
frontend/testem.log
frontend/typings/
.eslintcache
.npm
.node_repl_history
*.tgz
.yarn-integrity

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
*.pem
*.key
*.cert
secrets/

# ── Build artifacts ───────────────────────────────────────────────────────────
build/
dist/
tmp/
temp/
docs/build/

# ── Logs & runtime data ───────────────────────────────────────────────────────
*.log
logs/
pids/
*.pid
*.seed
*.pid.lock
coverage/
*.lcov
.nyc_output

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

